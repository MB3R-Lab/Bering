{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:io.mb3r.bering:release-manifest:1.0.0",
  "title": "BeringReleaseManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "product_name",
    "app_version",
    "git_commit",
    "build_date",
    "binaries",
    "checksums",
    "oci_images",
    "helm_chart",
    "contracts_pack",
    "contracts",
    "release_notes"
  ],
  "properties": {
    "schema": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "uri"],
      "properties": {
        "name": { "const": "io.mb3r.bering.release-manifest" },
        "version": { "const": "1.0.0" },
        "uri": { "const": "urn:io.mb3r.bering:release-manifest:1.0.0" }
      }
    },
    "product_name": { "type": "string", "const": "bering" },
    "app_version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "git_tag": { "type": "string", "pattern": "^v.+$" },
    "git_commit": { "type": "string", "minLength": 7 },
    "build_date": { "type": "string", "format": "date-time" },
    "binaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "os", "arch", "target", "binary", "path"],
        "properties": {
          "id": { "type": "string" },
          "os": { "type": "string" },
          "arch": { "type": "string" },
          "target": { "type": "string" },
          "binary": { "type": "string" },
          "path": { "type": "string" },
          "archive": { "type": "string" },
          "format": { "type": "string" },
          "archive_id": { "type": "string" },
          "sbom": { "type": "string" },
          "checksum": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
        }
      }
    },
    "checksums": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "file", "digest", "entries"],
      "properties": {
        "algorithm": { "const": "sha256" },
        "file": { "type": "string" },
        "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "path", "algorithm", "digest"],
            "properties": {
              "name": { "type": "string" },
              "path": { "type": "string" },
              "algorithm": { "const": "sha256" },
              "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
            }
          }
        }
      }
    },
    "oci_images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["repository", "references", "tags", "platforms", "published", "build_date", "git_commit"],
        "properties": {
          "repository": { "type": "string" },
          "references": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "tags": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
          "platforms": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "local_layout": { "type": "string" },
          "published": { "type": "boolean" },
          "media_type": { "type": "string" },
          "build_date": { "type": "string", "format": "date-time" },
          "git_commit": { "type": "string", "minLength": 7 },
          "source_artifact": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
        }
      }
    },
    "helm_chart": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "app_version", "package", "package_digest", "published", "source_chart_dir"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "app_version": { "type": "string" },
        "package": { "type": "string" },
        "package_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "oci_reference": { "type": "string" },
        "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "published": { "type": "boolean" },
        "repository": { "type": "string" },
        "source_chart_dir": { "type": "string" }
      }
    },
    "contracts_pack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["archive", "digest", "manifest"],
      "properties": {
        "archive": { "type": "string" },
        "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "manifest": { "type": "string" }
      }
    },
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "version", "kind", "file", "uri", "digest"],
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" },
          "kind": { "type": "string" },
          "file": { "type": "string" },
          "uri": { "type": "string", "format": "uri" },
          "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
        }
      }
    },
    "release_notes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headline", "summary", "highlights", "breaking"],
      "properties": {
        "headline": { "type": "string" },
        "summary": { "type": "string" },
        "highlights": {
          "type": "array",
          "items": { "type": "string" }
        },
        "breaking": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cli", "api", "install_surface", "schema_contracts"],
          "properties": {
            "cli": { "type": "boolean" },
            "api": { "type": "boolean" },
            "install_surface": { "type": "boolean" },
            "schema_contracts": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
